{
  "env": {
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(git add:*)",
      "Bash(sed:*)",
      "Bash(node:*)",
      "Bash(npm install:*)",
      "Bash(ls:*)",
      "Bash(grep:*)",
      "Bash(mkdir:*)",
      "Bash(npm run build:*)",
      "Bash(for lang in de es fr ru)",
      "Bash(do echo \"=== $lang ===\")",
      "Bash(done)",
      "Bash(find:*)",
      "Bash(cat:*)",
      "mcp__ide__getDiagnostics",
      "Bash(npx next build:*)",
      "Bash(npx acorn:*)",
      "WebSearch",
      "Bash(npx next:*)",
      "WebFetch(domain:restcountries.com)"
    ],
    "deny": [
      "Bash(git push:*)"
    ]
  }
}
