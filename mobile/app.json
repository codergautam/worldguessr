{
  "expo": {
    "name": "WorldGuessr",
    "slug": "worldguessr",
    "version": "2.3.0",
    "orientation": "default",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "worldguessr",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "cover",
      "backgroundColor": "#112b18"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "com.codergautamyt.worldguessr",
      "associatedDomains": [
        "applinks:worldguessr.com",
        "applinks:www.worldguessr.com"
      ],
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSUserTrackingUsageDescription": "Help us deliver a better personalized ad experience to you.",
        "FIREBASE_ANALYTICS_COLLECTION_ENABLED": true,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.471080734176-07tfkec1bhq6m2k5hid7dg6cemvi40kb"
            ]
          }
        ]
      },
      "googleServicesFile": "./GoogleService-Info.plist"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#112b18"
      },
      "versionCode": 24,
      "edgeToEdgeEnabled": true,
      "package": "com.codergautamyt.worldguessr",
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ],
          "data": [
            {
              "scheme": "https",
              "host": "worldguessr.com",
              "path": "/"
            },
            {
              "scheme": "https",
              "host": "worldguessr.com",
              "path": "/daily"
            },
            {
              "scheme": "https",
              "host": "worldguessr.com",
              "path": "/map"
            },
            {
              "scheme": "https",
              "host": "worldguessr.com",
              "pathPrefix": "/map/"
            },
            {
              "scheme": "https",
              "host": "worldguessr.com",
              "path": "/user"
            },
            {
              "scheme": "https",
              "host": "www.worldguessr.com",
              "path": "/"
            },
            {
              "scheme": "https",
              "host": "www.worldguessr.com",
              "path": "/daily"
            },
            {
              "scheme": "https",
              "host": "www.worldguessr.com",
              "path": "/map"
            },
            {
              "scheme": "https",
              "host": "www.worldguessr.com",
              "pathPrefix": "/map/"
            },
            {
              "scheme": "https",
              "host": "www.worldguessr.com",
              "path": "/user"
            }
          ]
        }
      ],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-localization",
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-3340825671684972~3527086275",
          "iosAppId": "ca-app-pub-3340825671684972~7929582209",
          "userTrackingUsageDescription": "Help us deliver a better personalized ad experience to you."
        }
      ],
      "@react-native-firebase/app",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.471080734176-07tfkec1bhq6m2k5hid7dg6cemvi40kb"
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static",
            "buildReactNativeFromSource": true
          }
        }
      ],
      [
        "expo-tracking-transparency",
        {
          "userTrackingPermission": "Help us deliver a better personalized ad experience to you."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "93315d25-7e8b-460c-9a83-648726688f71"
      }
    }
  }
}
